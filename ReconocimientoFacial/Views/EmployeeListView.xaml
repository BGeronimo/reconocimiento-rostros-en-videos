<UserControl x:Class="ReconocimientoFacial.Views.EmployeeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReconocimientoFacial.Views"
             xmlns:viewmodels="clr-namespace:ReconocimientoFacial.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
             
    <UserControl.DataContext>
        <viewmodels:EmployeeListViewModel />
    </UserControl.DataContext>

    <Grid Background="Transparent" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header y Búsqueda -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="SECURITY MODULE" Foreground="#7A8DAB" FontSize="12" FontWeight="SemiBold"/>
                <TextBlock Text="Listado de empleados" Foreground="#FFFFFF" FontSize="36" FontWeight="Bold" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Búsqueda -->
            <Border Grid.Column="1" Background="#111824" CornerRadius="12" BorderBrush="#1C2E4A" BorderThickness="1" Height="45" Padding="15,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" Foreground="#7A8DAB" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Grid>
            </Border>

            <!-- Boton Filtro (Opcional) -->
            <Button Grid.Column="2" Margin="15,0,0,0" Height="45" Width="130" Background="#1C2E4A" Foreground="#FFFFFF" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="⧨" Margin="0,0,10,0" Foreground="#00F2FF"/>
                                <TextBlock Text="DEPARTMENT" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Grilla (Cards) de Empleados -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Employees}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Width="220" Background="#0C1322" CornerRadius="15" Margin="0,0,30,30" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="10" Opacity="0.3" Direction="270" ShadowDepth="4"/>
                        </Border.Effect>
                        
                        <StackPanel>
                            <!-- Imagen y Estado -->
                            <Grid HorizontalAlignment="Left" Margin="0,0,0,15">
                                <Border Width="80" Height="80" CornerRadius="15" BorderBrush="#CF9FFF" BorderThickness="2">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding LocalProfileImagePath}" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                                
                                <!-- Insignia de Nivel Alpha en vista (Mock) -->
                                <Border Background="#1C2E4A" CornerRadius="8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="95,0,-60,0" Padding="8,4">
                                    <TextBlock Text="L-4 ALPHA" Foreground="#00F2FF" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                            
                            <!-- Información -->
                            <TextBlock Text="{Binding FullName}" Foreground="#FFFFFF" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding EmployeeCode}" Foreground="#CF9FFF" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock Text="Neural Network Supervisor" Foreground="#7A8DAB" FontSize="12" Margin="0,0,0,20"/>
                            
                            <!-- Acciones inferiores -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="✏" Foreground="#555" FontSize="14" Margin="0,0,15,0" Cursor="Hand"/>
                                <TextBlock Grid.Column="1" Text="🗑" Foreground="#555" FontSize="14" Cursor="Hand"/>
                                
                                <TextBlock Grid.Column="2" Text="VIEW LOGS &gt;" Foreground="#FFFFFF" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
            
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <!-- Eliminando efecto de selección por defecto de WPF -->
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </Grid>
</UserControl>